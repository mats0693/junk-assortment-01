    #optN[#i]=0;

return;

//パラメータ5つ・文字コード指定可能
SetMenuSub_EP5_TextOut:

    $$ShortKeyWord      = $$1;
    $$P2_Kak            = $$2;
    $$P1_PathType       = $$3;
    $$encode            = $$4;

    if($$ShortKeyWord==""){
        $$ShortKeyWord="TMP";
    }
    if($$P2_Kak==""){
        $$P2_Kak = "tmp";
    }
    if($$P1_PathType==""){
        $$P1_PathType = "MyWorkLog";
        //$$P1_PathType = "Desktop";
    }
    if($$encode==""){
        $$encode="utf8";
    }

    $$macFileName = $macrofile0510;
    //$$P1_PathType = "MyWorkLog";
    $$P3_OutFileHdr="log_temp_" + $ShortKeyWord + "_";
    $$P4_OutFileFtr="_TEMP";
    $$P5_encode=tolower($$encode);
    
    
    $$menuLabel="&" + $$ShortKeyWord + " tempファイル保存: " + $$P1_PathType + " ("+$$P2_Kak+")" + "["+toupper($$encode)+"]";
    
    #i=#i+1;
    #mID[#i]=1;
    $mTp[#i]="EP5";
    $optS[#i]=$$macFileName;
    $p1[#i]=$$P1_PathType;
    $p2[#i]="log.temp.text." + $$P2_Kak;
    $p3[#i]=$$P3_OutFileHdr;
    $p4[#i]=$$P4_OutFileFtr;
    $p5[#i]=$$P5_encode;
    $mnlbl[#i]=$$menuLabel;
    #optN[#i]=0;

return;

//パラメータ5つ・文字コード、ファイル名ヘッダの指定
SetMenuSub_EP5_TextOut_B:

    $$ShortKeyWord      = $$1;
    $$P2_Kak            = $$2;
    $$P1_PathType       = $$3;
    $$encode            = $$4;
    $$outfile_header = $$5;
    $$outfile_footer = $$6;

    if($$ShortKeyWord==""){
        $$ShortKeyWord="TMP";
    }
    if($$P2_Kak==""){
        $$P2_Kak = "tmp";
    }
    if($$P1_PathType==""){
        $$P1_PathType = "MyWorkLog";
        //$$P1_PathType = "Desktop";
    }
    if($$encode==""){
        $$encode="utf8";
    }

    $$macFileName = $macrofile0510;

    //$$P3_OutFileHdr="log_temp_" + $ShortKeyWord + "_";
    //$$P4_OutFileFtr="_TEMP";
    $$P3_OutFileHdr = $$outfile_header + "_" + $ShortKeyWord + "_";
    $$P4_OutFileFtr = "_" + $$outfile_footer;
    $$P5_encode=tolower($$encode);
    
    $$menuLabel="&" + $$ShortKeyWord + " tempファイル保存: " + $$P1_PathType + " ("+$$P2_Kak+")" + "["+toupper($$encode)+"]";
    
    #i=#i+1;
    #mID[#i]=1;
    $mTp[#i]="EP5";
    $optS[#i]=$$macFileName;
    $p1[#i]=$$P1_PathType;
    $p2[#i]="log.temp.text." + $$P2_Kak;
    $p3[#i]=$$P3_OutFileHdr;
    $p4[#i]=$$P4_OutFileFtr;
    $p5[#i]=$$P5_encode;
    $mnlbl[#i]=$$menuLabel;
    #optN[#i]=0;

return;


