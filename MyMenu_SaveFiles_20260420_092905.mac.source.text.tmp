SetMenuSub_EP4_TextOutUTF8:

    $$ShortKeyWord      = $$1;
    $$P2_Kak            = $$2;
    $$P1_PathType       = $$3;
    
    if($$ShortKeyWord==""){
        $$ShortKeyWord="TMP";
    }
    if($$P2_Kak==""){
        $$P2_Kak = "tmp";
    }
    if($$P1_PathType==""){
        $$P1_PathType = "MyWorkLog";
        //$$P1_PathType = "Desktop";
    }

    $$macFileName = $macrofile0010;
    //$$P1_PathType = "MyWorkLog";
    $$P3_OutFileHdr="log_temp_" + $ShortKeyWord + "_";
    $$P4_OutFileFtr="_TEMP";
    
    
    $$menuLabel="&" + $$ShortKeyWord + " tempファイル保存: " + $$P1_PathType + " ("+$$P2_Kak+")";
    
    #i=#i+1;
    #mID[#i]=1;
    $mTp[#i]="EP4";
    $optS[#i]=$$macFileName;
    $p1[#i]=$$P1_PathType;
    $p2[#i]="log.temp.text." + $$P2_Kak;
    $p3[#i]=$$P3_OutFileHdr;
    $p4[#i]=$$P4_OutFileFtr;
    $mnlbl[#i]=$$menuLabel;
    #optN[#i]=0;

return;

SetMenuSub_EP4_TextOutSJIS:

    $$ShortKeyWord      = $$1;
    $$P2_Kak            = $$2;
    $$P1_PathType       = $$3;
    
    if($$ShortKeyWord==""){
        $$ShortKeyWord="TMP";
    }
    if($$P2_Kak==""){
        $$P2_Kak = "tmp";
    }
    if($$P1_PathType==""){
        $$P1_PathType = "MyWorkLog";
        //$$P1_PathType = "Desktop";
    }

    $$macFileName = $macrofile0020;
    //$$P1_PathType = "MyWorkLog";
    $$P3_OutFileHdr="log_temp_" + $ShortKeyWord + "_";
    $$P4_OutFileFtr="_TEMP";
    
    
    $$menuLabel="&" + $$ShortKeyWord + " tempファイル保存: " + $$P1_PathType + " ("+$$P2_Kak+")";
    
    #i=#i+1;
    #mID[#i]=1;
    $mTp[#i]="EP4";
    $optS[#i]=$$macFileName;
    $p1[#i]=$$P1_PathType;
