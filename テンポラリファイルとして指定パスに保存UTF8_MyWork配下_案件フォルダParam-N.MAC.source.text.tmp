if(iskeydown(0x25)){
	call openThis();
	endmacro;
}else{
	call main();
}
endmacro;
openThis:
openfile currentmacrofilename;
return;
void:
return;
init:
	#sjis = 0x01;
	#utf16 = 0x02;
	#euc = 0x03;
	#jis = 0x04;
	#utf7 = 0x05;
	#utf8 = 0x06;
	#utf16_be = 0x07;
	#euro = 0x08;
	#gb2312 = 0x09;
	#big5 = 0x0A;
	#euckr = 0x0B;
	#johab = 0x0C;
	#easteuro = 0x0D;
	#baltic = 0x0E;
	#greek = 0x0F;
	#russian = 0x10;
	#symbol = 0x11;
	#turkish = 0x12;
	#hebrew = 0x13;
	#arabic = 0x14;
	#thai = 0x15;
	#vietnamese = 0x16;
	#mac = 0x17;
	#oem = 0x18;
	#default = 0x19;
	#utf32 = 0x1B;
	#utf32_be = 0x1C;
	#binary = 0x1A;
	#lf = 0x40;
	#cr = 0x80;
	#bom = 0x0600;
	#nobom = 0x0400;
	#selection = 0x2000;
	#noaddhist = 0x0100;
	#ws = 0x0800;
	#wb = 0x1000;
return;
main:
$param1 = getarg(0);
$param2 = getarg(1);
$param3 = getarg(2);
$param4 = getarg(3);
if($param1=="###OPEN###"){
	call openThis();
	endmacro;
}
call init();
	$thisfilename			= "";
	$thisfilepath			= "";
	$thisfilefullname		= "";
	$thisfilename_exclext	= "";
	$thisfileext			= "";
	if(filename2!=""){
		$msg = filename2 + "\n は、ファイルとして保存済みです。\n" + "[" + currentmacrobasename + "] マクロを実行しますか？";
		question $msg;
		if( result != yes ) {endmacro;}
		call init_filenameinfo();
	}else{
	}
	call init_date();
	$desktop = "C:\\Users\\japma\\Desktop\\";
	$currentdir = directory2 + "\\";
	$tempdir = "C:\\temp\\";
	$tmpdir = "C:\\tmp\\";
	$mywork = "C:\\MyWork\\";
	$mywork_TempWorkLog = "C:\\MyWork\\TempWorkLog\\";
	$workdir = $mywork_TempWorkLog;
	if($param1=="MyWork"){
		$workdir = $mywork;
	}else if($param1=="MyWorkLog"){
		$workdir = $mywork_TempWorkLog;
	}else if($param1=="Desktop"){
		$workdir = $desktop;
	}else if($param1=="Current"){
		$workdir = $currentdir;
	}else if($param1=="20250930_PBI"){
		$wfolder="20250930_Tableau_to_PowerBI★";
		$workdir = $mywork + $wfolder + "\\_textlog\\";
	}else{
		$workdir = $mywork_TempWorkLog;
	}
	$work_ext = ".tmplogtxt.text";
	if($param2!=""){
		$work_ext = "." + $param2;
	}
	$work_header = "log_";
	if($param3!=""){
		$work_header = $param3;
	}
	$work_footer = "_xxx";
	if($param4!=""){
		$work_footer = $param4;
	}
	saveas $workdir + $work_header + $ymdhms01 + $work_footer + $work_ext, utf8,cr,lf;
	message "保存しました。\n" + filename2;
endmacro;
init_date:
	$ys = year;
	$ms = month;
	$ds = day;
	$hs = hour;
	$ns = minute;
	$ss = second;
	$af = midstr("AMPM" ,(val($hs) / 12) * 2 , 2);
	$afj = "午" + midstr("前後" ,(val($hs) / 12) * 2 , 2);
	$ymd00 = $ys+"/"+$ms+"/"+$ds;
	$ymd01 = $ys+"."+$ms+"."+$ds;
	$ymd02 = $ys+"-"+$ms+"-"+$ds;
	$hms00 = $hs+":"+$ns+":"+$ss;
	$hms01 = $hs+":"+$ns;
	$ymdhms01 = $ys+""+$ms+""+$ds+"_"+$hs+""+$ns+""+$ss;
return;
init_filenameinfo:
	$thisfilename = basename2;
	$thisfilepath = directory2 + "\\";
	$thisfilefullname = filename2;
	$thisfilename_exclext = "";
	$thisfileext = "";
	#iPosEndDot = strrstr( basename2, "." );
	if(#iPosEndDot > 0){
		$thisfilename_exclext = leftstr( basename2, #iPosEndDot );
		$thisfileext = rightstr(basename2, strlen(basename2) - #iPosEndDot -1);
	}else{
		$thisfilename_exclext = basename2;
		$thisfileext = "";
	}
return;
